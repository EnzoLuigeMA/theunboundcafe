<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Unbound House Café — By Dox</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg-dark: #353a2c;
            --bg-card: #3e4434;
            --cream: #f0e2c8;
            --cream-light: #f5edd9;
            --cream-dim: #b8ad97;
            --gold: #c9b896;
            --accent: #a09270;
        }
        body {
            font-family: 'Playfair Display', 'Georgia', serif;
            background-color: var(--bg-dark);
            color: var(--cream);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 0;
            position: relative;
            overflow-x: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(160,146,112,0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(160,146,112,0.04) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }
        .noise-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 1;
        }
        .container { width: 100%; max-width: 440px; padding: 40px 24px 60px; position: relative; z-index: 2; }
        .header { text-align: center; margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid rgba(240,226,200,0.12); }
        .header-the { font-size: 11px; letter-spacing: 6px; text-transform: uppercase; color: var(--cream-dim); margin-bottom: 6px; font-weight: 400; }
        .header-title { font-size: 32px; font-weight: 700; letter-spacing: 1px; line-height: 1.1; margin-bottom: 12px; color: var(--cream-light); }
        .header-cafe { font-size: 13px; letter-spacing: 8px; text-transform: uppercase; color: var(--cream-dim); display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 14px; }
        .header-cafe::before, .header-cafe::after { content: ''; width: 40px; height: 1px; background: var(--cream-dim); opacity: 0.5; }
        .header-by { font-size: 16px; font-style: italic; font-weight: 400; color: var(--gold); }
        .location { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 16px; font-size: 12px; letter-spacing: 2px; color: var(--cream-dim); text-transform: uppercase; }
        .location svg { width: 14px; height: 14px; fill: var(--cream-dim); }
        .links { display: flex; flex-direction: column; gap: 14px; margin-bottom: 40px; }
        .link-item { display: flex; align-items: center; gap: 16px; padding: 18px 24px; background: rgba(240,226,200,0.04); border: 1px solid rgba(240,226,200,0.1); border-radius: 4px; text-decoration: none; color: var(--cream); transition: all 0.3s ease; cursor: pointer; }
        .link-item:hover { background: rgba(240,226,200,0.09); border-color: rgba(240,226,200,0.2); transform: translateY(-1px); }
        .link-item:active { transform: translateY(0); }
        .link-icon { width: 20px; height: 20px; flex-shrink: 0; opacity: 0.7; }
        .link-icon svg { width: 100%; height: 100%; fill: var(--gold); }
        .link-text { flex: 1; }
        .link-title { font-size: 15px; font-weight: 500; letter-spacing: 0.5px; margin-bottom: 2px; }
        .link-subtitle { font-size: 11px; color: var(--cream-dim); letter-spacing: 1px; font-style: italic; }
        .link-arrow { opacity: 0.3; transition: opacity 0.3s ease; }
        .link-item:hover .link-arrow { opacity: 0.6; }
        .link-arrow svg { width: 16px; height: 16px; fill: var(--cream); }
        .link-item.featured { background: rgba(201,184,150,0.1); border-color: rgba(201,184,150,0.25); }
        .link-item.featured:hover { background: rgba(201,184,150,0.15); border-color: rgba(201,184,150,0.35); }
        .hours-section { text-align: center; margin-bottom: 40px; padding: 28px 24px; background: rgba(240,226,200,0.03); border: 1px solid rgba(240,226,200,0.08); border-radius: 4px; }
        .hours-title { font-size: 11px; letter-spacing: 5px; text-transform: uppercase; color: var(--cream-dim); margin-bottom: 16px; }
        .hours-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; font-size: 13px; }
        .hours-day { color: var(--cream-dim); font-style: italic; }
        .hours-time { color: var(--cream); letter-spacing: 1px; }
        .hours-divider { width: 100%; height: 1px; background: rgba(240,226,200,0.06); margin: 8px 0; }
        .footer { text-align: center; padding-top: 24px; border-top: 1px solid rgba(240,226,200,0.08); }
        .footer-text { font-size: 11px; color: var(--cream-dim); letter-spacing: 2px; text-transform: uppercase; opacity: 0.6; }
        .footer-collab { margin-top: 8px; font-size: 13px; font-style: italic; color: var(--gold); opacity: 0.5; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .header { animation: fadeUp 0.6s ease both; }
        .link-item:nth-child(1) { animation: fadeUp 0.6s ease 0.10s both; }
        .link-item:nth-child(2) { animation: fadeUp 0.6s ease 0.15s both; }
        .link-item:nth-child(3) { animation: fadeUp 0.6s ease 0.20s both; }
        .link-item:nth-child(4) { animation: fadeUp 0.6s ease 0.25s both; }
        .link-item:nth-child(5) { animation: fadeUp 0.6s ease 0.30s both; }
        .link-item:nth-child(6) { animation: fadeUp 0.6s ease 0.35s both; }
        .hours-section { animation: fadeUp 0.6s ease 0.4s both; }
        .footer { animation: fadeUp 0.6s ease 0.5s both; }
    </style>
</head>
